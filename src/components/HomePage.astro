---
import Socials from './Socials.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { profile, education, projects, publications, social } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Repositório principal de cada projeto (full > code > frontend),
// usado no botão de destaque "ver o projeto completo no GitHub".
const repoOrder = ['full', 'code', 'frontend'] as const;
function mainRepo(p: (typeof projects)[number]) {
  for (const kind of repoOrder) {
    const link = p.links.find((l) => l.kind === kind);
    if (link) return { url: link.url, kind };
  }
  return null;
}
---

<!-- ============== HERO ============== -->
<section class="hero" id="top">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="eyebrow">{profile.role[lang]}</p>
      <h1>{profile.name}</h1>
      <p class="tagline">{profile.tagline[lang]}</p>
      <p class="location">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 21s-7-6.5-7-11a7 7 0 1 1 14 0c0 4.5-7 11-7 11Z" /><circle cx="12" cy="10" r="2.5" />
        </svg>
        {profile.location[lang]}
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#projects">{t('hero.cta.projects')}</a>
        <a class="btn btn-ghost" href="#contact">{t('hero.cta.contact')}</a>
      </div>

      <Socials variant="labeled" />
    </div>

    <img
      class="hero-photo"
      src={profile.photo}
      alt={profile.name}
      width="220"
      height="220"
      fetchpriority="high"
    />
  </div>
</section>

<!-- ============== ABOUT + EDUCATION ============== -->
<section id="about" class="about">
  <div class="container">
    <h2 class="section-title">{t('about.title')}</h2>
    {profile.about[lang].map((para) => <p>{para}</p>)}

    <div class="education">
      <h3>{t('about.education')}</h3>
      {
        education.map((e) => (
          <div class="edu-item">
            <div>
              <div class="degree">{e.degree[lang]}</div>
              <div class="school">{e.school[lang]}</div>
              {e.detail && <div class="edu-detail">{e.detail[lang]}</div>}
            </div>
            <div class="period">{e.period}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- ============== PUBLICATIONS ============== -->
{
  publications.length > 0 && (
    <section id="publications">
      <div class="container">
        <h2 class="section-title">{t('publications.title')}</h2>
        <p class="section-subtitle">{t('publications.subtitle')}</p>

        <div class="pub-list">
          {publications.map((pub) => (
            <div class="pub-item">
              <div class="pub-title">{pub.title}</div>
              <div class="pub-meta">
                {pub.authors} · {pub.venue[lang]} · <span class="year">{pub.year}</span>
                {pub.link && (
                  <>
                    {' · '}
                    <a href={pub.link} target="_blank" rel="noopener">
                      {t('publications.read')} ↗
                    </a>
                  </>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<!-- ============== PROJECTS ============== -->
<section id="projects">
  <div class="container">
    <h2 class="section-title">{t('projects.title')}</h2>
    <p class="section-subtitle">{t('projects.subtitle')}</p>
    <a class="projects-more" href={social.github} target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z" />
      </svg>
      {t('projects.more')} ↗
    </a>

    <div class="project-list">
      {
        projects.map((p) => {
          const repo = mainRepo(p);
          const otherLinks = p.links.filter((l) => !repo || l.kind !== repo.kind);
          return (
            <article class={`project${p.media ? '' : ' no-media'}`}>
              {p.media && (
                <div class="project-media">
                  <img src={p.media} alt={`${p.name} demo`} loading="lazy" />
                </div>
              )}

              <div class="project-body">
                <h3>
                  {p.name}
                  {p.status === 'wip' && <span class="wip-badge">{t('projects.wip')}</span>}
                </h3>
                <p>{p.description[lang]}</p>

                {p.highlights && (
                  <ul class="project-highlights">
                    {p.highlights[lang].map((h) => (
                      <li>{h}</li>
                    ))}
                  </ul>
                )}

                <div class="tags">
                  {p.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>

                {p.note && (
                  <p class="project-note">
                    <span aria-hidden="true">⏳</span> {p.note[lang]}
                  </p>
                )}

                {repo && (
                  <a class="btn-github" href={repo.url} target="_blank" rel="noopener">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z" />
                    </svg>
                    {t('projects.github')}
                    <span aria-hidden="true">→</span>
                  </a>
                )}

                {otherLinks.length > 0 && (
                  <div class="project-links">
                    {otherLinks.map((l) => (
                      <a
                        class={`link-pill${l.kind === 'demo' ? ' is-demo' : ''}`}
                        href={l.url}
                        target="_blank"
                        rel="noopener"
                      >
                        {t(`link.${l.kind}`)} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<!-- ============== CONTACT ============== -->
<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-title">{t('contact.title')}</h2>
    <p class="section-subtitle">{t('contact.subtitle')}</p>
    <a class="btn btn-primary" href={`mailto:${social.email}`}>{t('contact.email')}</a>
    <Socials />
  </div>
</section>
