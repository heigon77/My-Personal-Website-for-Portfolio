---
import { useTranslations, homePath, type Lang } from '../i18n/ui';
import { profile } from '../data/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const base = homePath[lang];
---

<header class="site-header">
  <div class="container">
    <a class="brand" href={base}>{profile.name}</a>

    <nav class="nav" aria-label="Primary">
      <div class="nav-links">
        <a href={`${base}#about`}>{t('nav.about')}</a>
        <a href={`${base}#publications`}>{t('nav.publications')}</a>
        <a href={`${base}#projects`}>{t('nav.projects')}</a>
        <a href={`${base}#contact`}>{t('nav.contact')}</a>
      </div>

      <div class="header-tools">
        <div class="lang-switch" role="group" aria-label="Language">
          <a href={homePath.en} aria-current={lang === 'en'}>EN</a>
          <a href={homePath.pt} aria-current={lang === 'pt'}>PT</a>
        </div>

        <button class="icon-btn" id="theme-toggle" type="button" aria-label={t('theme.toggle')} title={t('theme.toggle')}>
          <span aria-hidden="true">◐</span>
        </button>
      </div>
    </nav>
  </div>
</header>
