---
import { social } from '../data/content';

interface Props {
  // 'icon'    → só ícones (compacto)
  // 'labeled' → ícone + texto (github login, email, lattes em destaque)
  variant?: 'icon' | 'labeled';
}
const { variant = 'icon' } = Astro.props;
// login do GitHub a partir da URL (ex.: .../heigon77 → heigon77)
const githubUser = social.github.replace(/\/+$/, '').split('/').pop();
---

<div class={`socials${variant === 'labeled' ? ' labeled' : ''}`}>
  <a href={social.github} target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z" />
    </svg>
    <span class="social-label">{githubUser}</span>
  </a>

  <a href={`mailto:${social.email}`} aria-label="Email" title="Email">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d="m22 7-10 6L2 7" />
    </svg>
    <span class="social-label">{social.email}</span>
  </a>

  <a href={social.lattes} target="_blank" rel="noopener" aria-label="Currículo Lattes" title="Lattes (CV)">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2 1 7l11 5 9-4.09V15h2V7L12 2ZM5 11.18V15c0 1.1 3.13 3 7 3s7-1.9 7-3v-3.82l-7 3.18-7-3.18Z" />
    </svg>
    <span class="social-label">Lattes</span>
  </a>

  <a href={social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.5C0 23.2.8 24 1.77 24h20.45c.98 0 1.78-.8 1.78-1.76V1.74C24 .78 23.2 0 22.22 0Z" />
    </svg>
    <span class="social-label">LinkedIn</span>
  </a>
</div>
